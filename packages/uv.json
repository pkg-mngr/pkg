{
  "$schema": "../package.schema.json",
  "name": "uv",
  "description": "An extremely fast Python package and project manager, written in Rust.",
  "homepage": "https://docs.astral.sh/uv/",
  "version": "0.8.23",
  "sha256": {
    "linux-arm64": "503d1df80abe76c1f30264de817c9c847ff5fa457d4085517aecde1f5749ed66",
    "linux-x64": "b8d378bf1cbdefa6fd18570c3d5e7ea85066f75549cf3840212f505ed37522ed",
    "macos-arm64": "e9128449ea08a3c953f0e08dabc78c7588361a898e6bd8163e7e8f8c96adeb66",
    "macos-x64": "bbb1db369de63d85334e2c43bb925fce63261cefa8c1a8569a6bd4c520f03c0d"
  },
  "url": {
    "linux-arm64": "https://github.com/astral-sh/uv/releases/download/{{ version }}/uv-aarch64-unknown-linux-gnu.tar.gz",
    "linux-x64": "https://github.com/astral-sh/uv/releases/download/{{ version }}/uv-x86_64-unknown-linux-gnu.tar.gz",
    "macos-arm64": "https://github.com/astral-sh/uv/releases/download/{{ version }}/uv-aarch64-apple-darwin.tar.gz",
    "macos-x64": "https://github.com/astral-sh/uv/releases/download/{{ version }}/uv-x86_64-apple-darwin.tar.gz"
  },
  "scripts": {
    "install": {
      "linux-arm64": [
        "tar -xf uv-aarch64-unknown-linux-gnu.tar.gz",
        "install uv-aarch64-unknown-linux-gnu/* {{ pkg.bin_dir }}"
      ],
      "linux-x64": [
        "tar -xf uv-x86_64-unknown-linux-gnu.tar.gz",
        "install uv-x86_64-unknown-linux-gnu/* {{ pkg.bin_dir }}"
      ],
      "macos-arm64": [
        "tar -xf uv-aarch64-apple-darwin.tar.gz",
        "install uv-aarch64-apple-darwin/* {{ pkg.bin_dir }}"
      ],
      "macos-x64": [
        "tar -xf uv-x86_64-apple-darwin.tar.gz",
        "install uv-x86_64-apple-darwin/* {{ pkg.bin_dir }}"
      ]
    },
    "latest": [
      "gh release list -R astral-sh/uv --json tagName --jq '.[0].tagName'"
    ],
    "completions": {
      "linux-arm64": [
        "uv generate-shell-completion zsh > {{ pkg.completions.zsh }}/_uv",
        "uvx --generate-shell-completion zsh > {{ pkg.completions.zsh }}/_uvx"
      ],
      "linux-x64": [
        "uv generate-shell-completion zsh > {{ pkg.completions.zsh }}/_uv",
        "uvx --generate-shell-completion zsh > {{ pkg.completions.zsh }}/_uvx"
      ],
      "macos-arm64": [
        "uv generate-shell-completion zsh > {{ pkg.completions.zsh }}/_uv",
        "uvx --generate-shell-completion zsh > {{ pkg.completions.zsh }}/_uvx"
      ],
      "macos-x64": [
        "uv generate-shell-completion zsh > {{ pkg.completions.zsh }}/_uv",
        "uvx --generate-shell-completion zsh > {{ pkg.completions.zsh }}/_uvx"
      ]
    }
  }
}
