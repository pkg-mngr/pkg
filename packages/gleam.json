{
  "$schema": "../package.schema.json",
  "name": "gleam",
  "description": "A friendly language for building type-safe, scalable systems!",
  "homepage": "https://gleam.run",
  "version": "1.13.0-rc1",
  "sha256": {
    "linux-arm64": "8725b6457fe0f2fbfe044046a2941b200d8e05a11bea961da9fd17047fc3d50d",
    "linux-x64": "3fdc4becaf5e3f6f53ed1e89527e415241a4eab7d81316aeac9a73b55da62922",
    "macos-arm64": "a8f095d9f38413b2ad66a82b32465eaea6cf39c34927ea5a07b3aacaf0ae9d49",
    "macos-x64": "2237e801b0d7a01df3ffd67c1de06d04045dc496ecb8d6d33c727504398f2972"
  },
  "url": {
    "linux-arm64": "https://github.com/gleam-lang/gleam/releases/download/v{{ version }}/gleam-v{{ version }}-aarch64-unknown-linux-musl.tar.gz",
    "linux-x64": "https://github.com/gleam-lang/gleam/releases/download/v{{ version }}/gleam-v{{ version }}-x86_64-unknown-linux-musl.tar.gz",
    "macos-arm64": "https://github.com/gleam-lang/gleam/releases/download/v{{ version }}/gleam-v{{ version }}-aarch64-apple-darwin.tar.gz",
    "macos-x64": "https://github.com/gleam-lang/gleam/releases/download/v{{ version }}/gleam-v{{ version }}-x86_64-apple-darwin.tar.gz"
  },
  "caveats": "To use the Erlang target, you'll need to install Erlang and Rebar3. To use the JavaScript target, you'll need to install a JavaScript runtime like Node, Deno or Bun.",
  "scripts": {
    "install": {
      "linux-arm64": [
        "tar -xf gleam-v{{ version }}-aarch64-unknown-linux-musl.tar.gz",
        "install gleam {{ pkg.bin_dir }}"
      ],
      "linux-x64": [
        "tar -xf gleam-v{{ version }}-x86_64-unknown-linux-musl.tar.gz",
        "install gleam {{ pkg.bin_dir }}"
      ],
      "macos-arm64": [
        "tar -xf gleam-v{{ version }}-aarch64-apple-darwin.tar.gz",
        "install gleam {{ pkg.bin_dir }}"
      ],
      "macos-x64": [
        "tar -xf gleam-v{{ version }}-x86_64-apple-darwin.tar.gz",
        "install gleam {{ pkg.bin_dir }}"
      ]
    },
    "latest": [
      "gh release list -R gleam-lang/gleam --json tagName --jq '.[0].tagName' | cut -c 2-"
    ]
  }
}
