{
  "$schema": "../package.schema.json",
  "name": "bun",
  "description": "Incredibly fast JavaScript runtime, bundler, test runner, and package manager – all in one",
  "homepage": "https://bun.com",
  "version": "1.2.23",
  "sha256": {
    "linux-arm64": "6a7a98c546d084a845deda62eb2a5b94a6a14a63ea81cf9186d46bf55bf910a9",
    "linux-x64": "cf0ed0a920799d576ffde4e0cae66d732bf23c2530407f26f59c7831dffe1f0e",
    "macos-arm64": "22f5fa3fff72b0d3b8e7e0f8051ecadf2e41920d474ac62db5279144809c9005",
    "macos-x64": "9729c400e50bc3c86b6640e42af2ff5c057b5df3b27c93b40ed47c16b5e6a5e6"
  },
  "url": {
    "linux-arm64": "https://github.com/oven-sh/bun/releases/download/bun-v{{ version }}/bun-linux-aarch64.zip",
    "linux-x64": "https://github.com/oven-sh/bun/releases/download/bun-v{{ version }}/bun-linux-x64.zip",
    "macos-arm64": "https://github.com/oven-sh/bun/releases/download/bun-v{{ version }}/bun-darwin-aarch64.zip",
    "macos-x64": "https://github.com/oven-sh/bun/releases/download/bun-v{{ version }}/bun-darwin-x64.zip"
  },
  "caveats": "Due to the way Bun installs shell completions, they will not be installed during package installation. Instead, you can manually run `bun completions` to get completions for your shell.",
  "scripts": {
    "install": {
      "linux-arm64": [
        "unzip bun-linux-aarch64.zip",
        "install ./bun-linux-aarch64/bun {{ pkg.bin_dir }}/bun"
      ],
      "linux-x64": [
        "unzip bun-linux-x64.zip",
        "install ./bun-linux-x64/bun {{ pkg.bin_dir }}/bun"
      ],
      "macos-arm64": [
        "unzip bun-darwin-aarch64.zip",
        "install ./bun-darwin-aarch64/bun {{ pkg.bin_dir }}/bun"
      ],
      "macos-x64": [
        "unzip bun-darwin-x64.zip",
        "install ./bun-darwin-x64/bun {{ pkg.bin_dir }}/bun"
      ]
    },
    "latest": [
      "gh release list -R oven-sh/bun --json tagName --jq '.[0].tagName' | cut -c 6-"
    ]
  }
}
