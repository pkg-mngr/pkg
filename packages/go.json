{
  "$schema": "../package.schema.json",
  "name": "go",
  "description": "The Go programming language",
  "homepage": "https://go.dev",
  "version": "1.25.2",
  "sha256": {
    "linux-arm64": "9aaeb044bf8dbf50ca2fbf0edc5ebc98b90d5bda8c6b2911526df76f61232919",
    "linux-x64": "d7fa7f8fbd16263aa2501d681b11f972a5fd8e811f7b10cb9b26d031a3d7454b",
    "macos-arm64": "d1ade1b480e51b6269b6e65856c602aed047e1f0d32fffef7eebbd7faa8d7687",
    "macos-x64": "95493abb01da81638ab5083ff3f97e8f923cb42a64c2e16728e3cf5b0cd3fc5a"
  },
  "url": {
    "linux-arm64": "https://go.dev/dl/go{{ version }}.linux-arm64.tar.gz",
    "linux-x64": "https://go.dev/dl/go{{ version }}.linux-amd64.tar.gz",
    "macos-arm64": "https://go.dev/dl/go{{ version }}.darwin-arm64.tar.gz",
    "macos-x64": "https://go.dev/dl/go{{ version }}.darwin-amd64.tar.gz"
  },
  "scripts": {
    "install": {
      "linux-arm64": [
        "tar -xf go{{ version }}.linux-arm64.tar.gz go",
        "mv go {{ pkg.opt_dir }}/go",
        "ln -sf {{ pkg.opt_dir }}/go/bin/* {{ pkg.bin_dir }}"
      ],
      "linux-x64": [
        "tar -xf go{{ version }}.linux-amd64.tar.gz go",
        "mv go {{ pkg.opt_dir }}/go",
        "ln -sf {{ pkg.opt_dir }}/go/bin/* {{ pkg.bin_dir }}"
      ],
      "macos-arm64": [
        "tar -xf go{{ version }}.darwin-arm64.tar.gz go",
        "mv go {{ pkg.opt_dir }}/go",
        "ln -sf {{ pkg.opt_dir }}/go/bin/* {{ pkg.bin_dir }}"
      ],
      "macos-x64": [
        "tar -xf go{{ version }}.darwin-amd64.tar.gz go",
        "mv go {{ pkg.opt_dir }}/go",
        "ln -sf {{ pkg.opt_dir }}/go/bin/* {{ pkg.bin_dir }}"
      ]
    },
    "latest": [
      "curl -fsSL \"https://go.dev/VERSION?m=text\" | grep 'go*' | cut -c 3-"
    ]
  }
}
