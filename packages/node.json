{
  "$schema": "../package.schema.json",
  "name": "node",
  "description": "Node.js JavaScript runtime",
  "homepage": "https://nodejs.org",
  "version": "24.9.0",
  "sha256": {
    "linux-arm64": "dab232a90169737a48149149dd6707e7fdcbaefbaa94b4871047a38e93db947f",
    "linux-x64": "d57d6c28a35785f58f33899a0aa0bfc83f7a8ef4448b6cf3f7d0961efc7b9189",
    "macos-arm64": "961024296c2a8e60daed0784f8b61e0fab5c51d197502a92eff052c72b53209b",
    "macos-x64": "6c9ac12d3160538d96d456dc59a8fec1479e3f8b20bfc0d61bc809eb9ec11417"
  },
  "url": {
    "linux-arm64": "https://nodejs.org/dist/v{{ version }}/node-v{{ version }}-linux-arm64.tar.gz",
    "linux-x64": "https://nodejs.org/dist/v{{ version }}/node-v{{ version }}-linux-x64.tar.gz",
    "macos-arm64": "https://nodejs.org/dist/v{{ version }}/node-v{{ version }}-darwin-arm64.tar.gz",
    "macos-x64": "https://nodejs.org/dist/v{{ version }}/node-v{{ version }}-darwin-x64.tar.gz"
  },
  "scripts": {
    "install": {
      "linux-arm64": [
        "tar -xf node-v{{ version }}-linux-arm64.tar.gz",
        "mv node-v{{ version }}-linux-arm64 {{ pkg.opt_dir }}/node",
        "ln -sf {{ pkg.opt_dir }}/node/bin/* {{ pkg.bin_dir }}"
      ],
      "linux-x64": [
        "tar -xf node-v{{ version }}-linux-x64.tar.gz",
        "mv node-v{{ version }}-linux-x64 {{ pkg.opt_dir }}/node",
        "ln -sf {{ pkg.opt_dir }}/node/bin/* {{ pkg.bin_dir }}"
      ],
      "macos-arm64": [
        "tar -xf node-v{{ version }}-darwin-arm64.tar.gz",
        "mv node-v{{ version }}-darwin-arm64 {{ pkg.opt_dir }}/node",
        "ln -sf {{ pkg.opt_dir }}/node/bin/* {{ pkg.bin_dir }}"
      ],
      "macos-x64": [
        "tar -xf node-v{{ version }}-darwin-x64.tar.gz",
        "mv node-v{{ version }}-darwin-x64 {{ pkg.opt_dir }}/node",
        "ln -sf {{ pkg.opt_dir }}/node/bin/* {{ pkg.bin_dir }}"
      ]
    },
    "latest": [
      "curl -fsSL https://nodejs.org/dist/index.json | jq '.[0].version' -r | cut -c 2-"
    ]
  }
}
