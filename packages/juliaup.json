{
  "$schema": "../package.schema.json",
  "name": "juliaup",
  "description": "Julia installer and version multiplexer",
  "homepage": "https://julialang.org",
  "version": "1.18.2",
  "sha256": {
    "linux-arm64": "e26681931ef5434f3909b39befa9fa2ecbd45cd733ab43fc2078c94beab6921e",
    "linux-x64": "81e855680815e6e30cc978f3ca963abfb26f18aabbc1faa32b38be2495a9c356",
    "macos-arm64": "8d94d8381021d180c01ad40abcb77b5ea7c4c866165151992d5a549304fca2fe",
    "macos-x64": "121534067911f7533f326ba1838e8e2da54e9df564d9d141dea2389e73d398e2"
  },
  "url": {
    "linux-arm64": "https://github.com/JuliaLang/juliaup/releases/download/v{{ version }}/juliaup-{{ version }}-aarch64-unknown-linux-musl-portable.tar.gz",
    "linux-x64": "https://github.com/JuliaLang/juliaup/releases/download/v{{ version }}/juliaup-{{ version }}-x86_64-unknown-linux-musl-portable.tar.gz",
    "macos-arm64": "https://github.com/JuliaLang/juliaup/releases/download/v{{ version }}/juliaup-{{ version }}-aarch64-apple-darwin-portable.tar.gz",
    "macos-x64": "https://github.com/JuliaLang/juliaup/releases/download/v{{ version }}/juliaup-{{ version }}-x86_64-apple-darwin-portable.tar.gz"
  },
  "caveats": "To initialise `juliaup`, set a default toolchain by running `juliaup add release`.",
  "scripts": {
    "install": {
      "linux-arm64": [
        "tar -xf juliaup-{{ version }}-aarch64-unknown-linux-musl-portable.tar.gz",
        "install julia juliaup {{ pkg.bin_dir }}"
      ],
      "linux-x64": [
        "tar -xf juliaup-{{ version }}-x86_64-unknown-linux-musl-portable.tar.gz",
        "install julia juliaup {{ pkg.bin_dir }}"
      ],
      "macos-arm64": [
        "tar -xf juliaup-{{ version }}-aarch64-apple-darwin-portable.tar.gz",
        "install julia juliaup {{ pkg.bin_dir }}"
      ],
      "macos-x64": [
        "tar -xf juliaup-{{ version }}-x86_64-apple-darwin-portable.tar.gz",
        "install julia juliaup {{ pkg.bin_dir }}"
      ]
    },
    "latest": [
      "gh release list -R JuliaLang/juliaup --exclude-pre-releases --json tagName --jq '.[0].tagName' | cut -c 2-"
    ],
    "completions": {
      "linux-arm64": [
        "juliaup completions zsh > {{ pkg.completions.zsh }}/_juliaup"
      ],
      "linux-x64": [
        "juliaup completions zsh > {{ pkg.completions.zsh }}/_juliaup"
      ],
      "macos-arm64": [
        "juliaup completions zsh > {{ pkg.completions.zsh }}/_juliaup"
      ],
      "macos-x64": [
        "juliaup completions zsh > {{ pkg.completions.zsh }}/_juliaup"
      ]
    }
  }
}
