{
  "$schema": "../package.schema.json",
  "name": "flyctl",
  "description": "Command line tools for fly.io services",
  "homepage": "https://fly.io",
  "version": "0.3.191",
  "sha256": {
    "linux-arm64": "f24ccd61d3e628776c8e4b21dc736c0cff7098453d2440e0ab7a013b930f5b7c",
    "linux-x64": "53544469dca49977e444773d2ac88e15714543fdd55b1ad7d4a02d4435693a1b",
    "macos-arm64": "32ea33dc60abfa091b10125f876b1339b408acd784fe080f1fa0bb4ed743bae8",
    "macos-x64": "53f98b304d0dc3df8a02344e2c453d83a44316b9c6aa2ab674316b40bb99b1da"
  },
  "url": {
    "linux-arm64": "https://github.com/superfly/flyctl/releases/download/v{{ version }}/flyctl_{{ version }}_Linux_arm64.tar.gz",
    "linux-x64": "https://github.com/superfly/flyctl/releases/download/v{{ version }}/flyctl_{{ version }}_Linux_x86_64.tar.gz",
    "macos-arm64": "https://github.com/superfly/flyctl/releases/download/v{{ version }}/flyctl_{{ version }}_macOS_arm64.tar.gz",
    "macos-x64": "https://github.com/superfly/flyctl/releases/download/v{{ version }}/flyctl_{{ version }}_macOS_x86_64.tar.gz"
  },
  "scripts": {
    "install": {
      "linux-arm64": [
        "tar -xf flyctl_{{ version }}_Linux_arm64.tar.gz",
        "install flyctl {{ pkg.bin_dir }}"
      ],
      "linux-x64": [
        "tar -xf flyctl_{{ version }}_Linux_x86_64.tar.gz",
        "install flyctl {{ pkg.bin_dir }}"
      ],
      "macos-arm64": [
        "tar -xf flyctl_{{ version }}_macOS_arm64.tar.gz",
        "install flyctl {{ pkg.bin_dir }}"
      ],
      "macos-x64": [
        "tar -xf flyctl_{{ version }}_macOS_x86_64.tar.gz",
        "install flyctl {{ pkg.bin_dir }}"
      ]
    },
    "latest": [
      "gh release list -R superfly/flyctl --json tagName --jq '.[0].tagName' | cut -c 2-"
    ],
    "completions": {
      "linux-arm64": [
        "flyctl completion zsh > {{ pkg.completions.zsh }}/_flyctl"
      ],
      "linux-x64": [
        "flyctl completion zsh > {{ pkg.completions.zsh }}/_flyctl"
      ],
      "macos-arm64": [
        "flyctl completion zsh > {{ pkg.completions.zsh }}/_flyctl"
      ],
      "macos-x64": [
        "flyctl completion zsh > {{ pkg.completions.zsh }}/_flyctl"
      ]
    }
  }
}
